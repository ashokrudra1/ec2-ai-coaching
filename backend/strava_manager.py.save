import os
import httpx
import logging
from datetime import datetime, timedelta
from typing import Dict, Optional

from backend.database import SessionLocal
from backend.models import User, Activity, StravaToken
from backend.analytics import update_user_fitness_metrics
from backend.notifications import send_telegram_message
from backend.time_utils import utc_to_ist
from backend.orchestration.coach_service import CoachService
logger = logging.getLogger(__name__)


class StravaManager:
    def __init__(self):
        self.client_id = os.getenv("STRAVA_CLIENT_ID")
        self.client_secret = os.getenv("STRAVA_CLIENT_SECRET")
        self.base_url = "https://www.strava.com/api/v3"

    # =========================
    # 🔐 TOKEN MANAGEMENT
    # =========================
    async def get_valid_token(self, db, user_id: int) -> Optional[str]:
        token = db.query(StravaToken).filter_by(user_id=user_id).first()
        if not token:
            return None

        now = datetime.utcnow().timestamp()

        # If still valid
        if now < (token.expires_at - 300):
            return token.access_token

        logger.info(f"🔄 Refreshing token for user {user_id}")

        async with httpx.AsyncClient() as client:
            resp = await client.post(
                "https://www.strava.com/oauth/token",
                data={
                    "client_id": self.client_id,
                    "client_secret": self.client_secret,
                    "grant_type": "refresh_token",
                    "refresh_token": token.refresh_token
                },
                timeout=10
            )

        if resp.status_code != 200:
            logger.error(f"❌ Token refresh failed: {resp.text}")
            return None

        data = resp.json()

        token.access_token = data["access_token"]
        token.refresh_token = data["refresh_token"]
        token.expires_at = data["expires_at"]

        db.commit()
        return token.access_token

    # =========================
    # 📥 FETCH SINGLE ACTIVITY
    # =========================
    async def fetch_activity(self, token: str, activity_id: int) -> Dict:
        async with httpx.AsyncClient() as client:
            res = await client.get(
                f"{self.base_url}/activities/{activity_id}",
                headers={"Authorization": f"Bearer {token}"},
                timeout=10
            )

        if res.status_code != 200:
            logger.error(f"❌ Failed to fetch activity {activity_id}")
            return {}

        return res.json()

    # =========================
    # 💾 CORE PROCESSOR (SINGLE SOURCE OF TRUTH)
    # =========================
    def process_activity(self, db, user: User, act: Dict):
        # 🔁 DEDUPLICATION
        exists = db.query(Activity).filter_by(strava_id=str(act["id"])).first()
        if exists:
            return

        new_activity = Activity(
            user_id=user.id,
            strava_id=str(act["id"]),
            name=act.get("name"),
            distance_km=act.get("distance", 0) / 1000,
            moving_time_min=act.get("moving_time", 0) / 60,
            elapsed_time_min=act.get("elapsed_time", 0) / 60,
            type=act.get("type"),
            start_date_ist=utc_to_ist(act.get("start_date")),
            avg_heart_rate=act.get("average_heartrate"),
            max_heart_rate=act.get("max_heartrate")
        )

        db.add(new_activity)
        db.commit()
        db.refresh(new_activity)

        logger.info(f"🏃 Activity saved: {new_activity.name}")

        # 📊 Update metrics
        update_user_fitness_metrics(db, user.id)

        # 🧠 Generate coaching
        response = generate_coaching_decision(
            db=db,
            user_id=user.id,
            activity_data=new_activity
        )

        # 📩 Send Telegram
        if user.telegram_chat_id:
            send_telegram_message(
                f"🏃 {new_activity.name}\n\n{response}",
                user.telegram_chat_id
            )

    # =========================
    # 🔄 SYNC (LATEST ACTIVITIES)
    # =========================
    async def sync_recent(self):
        db = SessionLocal()

        try:
            users = db.query(User).all()

            for user in users:
                token = await self.get_valid_token(db, user.id)
                if not token:
                    continue

                async with httpx.AsyncClient() as client:
                    res = await client.get(
                        f"{self.base_url}/athlete/activities",
                        headers={"Authorization": f"Bearer {token}"},
                        params={"per_page": 10},
                        timeout=10
                    )

                if res.status_code != 200:
                    continue

                activities = res.json()

                for act in activities:
                    self.process_activity(db, user, act)

        finally:
            db.close()

    # =========================
    # 📚 BACKFILL HISTORY
    # =========================
    async def backfill(self, user_id: int, days: int = 30):
        db = SessionLocal()

        try:
            user = db.query(User).filter_by(id=user_id).first()
            if not user:
                return 0

            token = await self.get_valid_token(db, user_id)
            if not token:
                return 0

            after = int((datetime.utcnow() - timedelta(days=days)).timestamp())

            page = 1
            total = 0

            async with httpx.AsyncClient() as client:
                while True:
                    res = await client.get(
                        f"{self.base_url}/athlete/activities",
                        headers={"Authorization": f"Bearer {token}"},
                        params={"after": after, "per_page": 50, "page": page},
                        timeout=10
                    )

                    if res.status_code != 200:
                        break

                    activities = res.json()
                    if not activities:
                        break

                    for act in activities:
                        self.process_activity(db, user, act)

                    total += len(activities)

                    if len(activities) < 50:
                        break

                    page += 1

            return total

        finally:
            db.close()

    # =========================
    # ⚡ WEBHOOK HANDLER
    # =========================
    async def handle_webhook(self, athlete_id: int, activity_id: int):
        db = SessionLocal()

        try:
            token_rec = db.query(StravaToken).filter_by(athlete_id=athlete_id).first()
            if not token_rec:
                return

            user = db.query(User).filter_by(id=token_rec.user_id).first()
            if not user:
                return

            token = await self.get_valid_token(db, user.id)
            if not token:
                return

            activity = await self.fetch_activity(token, activity_id)

            if activity:
                self.process_activity(db, user, activity)

        finally:
            db.close()


# ✅ GLOBAL INSTANCE
strava_manager = StravaManager()
